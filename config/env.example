# Nik AI Assistant — environment variables
# Copy this to ~/.openclaw.env inside the VM, fill in real values, chmod 600.
# DO NOT commit a filled-in version.

# Anthropic API key (https://console.anthropic.com/settings/keys)
# Set a monthly spend limit on this key before using it.
export ANTHROPIC_API_KEY=""

# Discord bot token (https://discord.com/developers/applications/<APP_ID>/bot)
# Reset the token if it has ever been pasted into chat or screenshots.
export DISCORD_BOT_TOKEN=""
